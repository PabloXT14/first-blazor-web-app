@page "/counter"
@rendermode InteractiveServer



<PageTitle>Counter</PageTitle>

<div>
    <h1>Counter</h1>
    <p role="status">Current count: @currentCount</p>
    
    <div class="mb-4">
        @* Lambda expression: *@
        <button class="btn btn-primary" @onclick="() => currentCount++">Plus 1</button>

        <button class="btn btn-primary" @onclick="IncrementCount">Plus 3</button>
    </div>

    <input type="text" @oninput="HandleInput" />
    <p>@inputText</p>
    
    <div Class="box-container" @onmouseover="OnMouseOver" @onmouseout="OnMouseOut">
        @if(showText) {
            <p>
                Text to display when mouse is over the box
            </p>
        }   
    </div>
    
    <input @onkeydown="OnKeyDown" />
    
    <p>
        Last key pressed: @lastKeyPressed
    </p>
    
    <div class="box">
        <input type="text" @onfocus="HandleFocus" @onblur="HandleUnfocus" />
        <p>@focusAndUnfocusText</p>
    </div>
</div>


@code {
    private int currentCount = 0;
    private bool showText = false;

    private string inputText = string.Empty;
    private string lastKeyPressed = string.Empty;
    private string focusAndUnfocusText = string.Empty;

    [Parameter]
    public int IncrementAmount { get; set; }
    
    private void IncrementCount()
    {
        currentCount += IncrementAmount;
    }

    private void HandleInput(ChangeEventArgs e)
    {
        inputText = (string)e.Value?.ToString();
    }

    private void OnMouseOver(MouseEventArgs e)
    {
        showText = true;
    }

    private void OnMouseOut(MouseEventArgs e)
    {
        showText = false;
    }
    
    private void OnKeyDown(KeyboardEventArgs e)
    {
        lastKeyPressed = e.Key;
    }

    private void HandleFocus(FocusEventArgs e)
    {
        focusAndUnfocusText = "Input focused";
    }
    
    private void HandleUnfocus(FocusEventArgs e)
    {
        focusAndUnfocusText = "Input unfocused";
    }
}